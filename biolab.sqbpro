n index="2" value="58"/><column index="3" value="39"/><column index="4" value="61"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="OrderTest" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="53"/><column index="2" value="44"/><column index="3" value="71"/><column index="4" value="66"/><column index="5" value="76"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="Patient" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="60"/><column index="2" value="63"/><column index="3" value="61"/><column index="4" value="73"/><column index="5" value="47"/><column index="6" value="43"/><column index="7" value="52"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="SEQUENCE" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="132"/><column index="2" value="77"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table><table schema="main" name="user" show_row_id="0" encoding="" plot_x_axis="" unlock_view_pk="_rowid_" freeze_columns="0"><sort/><column_widths><column index="1" value="29"/><column index="2" value="300"/><column index="3" value="65"/><column index="4" value="78"/><column index="5" value="85"/><column index="6" value="47"/></column_widths><filter_values/><conditional_formats/><row_id_formats/><display_formats/><hidden_columns/><plot_y_axes/><global_filter/></table></browse_table_settings></tab_browse><tab_sql><sql name="SQL 1*">CREATE TABLE Administrator (

    adminId INTEGER PRIMARY KEY AUTOINCREMENT,

    fullName TEXT,

    email TEXT

);

CREATE TABLE Patient (

    patientId INTEGER PRIMARY KEY AUTOINCREMENT,

    firstName TEXT,

    lastName TEXT,

    dateOfBirth TEXT,

    gender TEXT,

    phone TEXT,

    address TEXT

);

CREATE TABLE Physician (

    physicianId INTEGER PRIMARY KEY AUTOINCREMENT,

    firstName TEXT,

    lastName TEXT,

    specialty TEXT,

    phone TEXT,

    email TEXT

);

CREATE TABLE LaboratoryTechnician (

    technicianId INTEGER PRIMARY KEY AUTOINCREMENT,

    fullName TEXT,

    email TEXT,

    lastName TEXT

);

CREATE TABLE TestCategory (

    categoryId INTEGER PRIMARY KEY AUTOINCREMENT,

    categoryName TEXT,

    description TEXT

);

CREATE TABLE Test (

    testId INTEGER PRIMARY KEY AUTOINCREMENT,

    testName TEXT,

    unit TEXT,

    description TEXT

);

CREATE TABLE ReferenceRange (

    referenceId INTEGER PRIMARY KEY AUTOINCREMENT,

    minValue REAL,

    maxValue REAL,

    criticalMin REAL,

    criticalMax REAL,

    units TEXT

);

CREATE TABLE Report (

    reportId INTEGER PRIMARY KEY AUTOINCREMENT,

    reportType TEXT,

    generatedDate TEXT

);

CREATE TABLE Sample (

    sampleId INTEGER PRIMARY KEY AUTOINCREMENT,

    sampleType TEXT,

    collectionDate TEXT,

    status TEXT

);

CREATE TABLE LaboratoryOrder (

    orderId INTEGER PRIMARY KEY AUTOINCREMENT,

    patientId INTEGER,

    physicianId INTEGER,

    orderDate TEXT,

    status TEXT,

    FOREIGN KEY (patientId)
    REFERENCES Patient(patientId)
    ON DELETE RESTRICT,

    FOREIGN KEY (physicianId)
    REFERENCES Physician(physicianId)
    ON DELETE RESTRICT

);

CREATE TABLE OrderTest (

    orderId INTEGER,

    testId INTEGER,

    resultValue REAL,

    resultDate TEXT,

    resultStatus TEXT,

    PRIMARY KEY (orderId, testId),

    FOREIGN KEY (orderId)
    REFERENCES LaboratoryOrder(orderId)
    ON DELETE RESTRICT,

    FOREIGN KEY (testId)
    REFERENCES Test(testId)
    ON DELETE RESTRICT

);</sql><current_tab id="0"/></tab_sql></sqlb_project>
